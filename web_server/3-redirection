#!/usr/bin/env bash
# Configure Nginx redirection /redirect_me -> YouTube

# Install nginx
apt-get -y update
apt-get -y install nginx

# Overwrite default config with specific configuration
cat <<EOF > /etc/nginx/sites-available/default
##
# Default Nginx site configuration
##

server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;

    server_name _;

    # Default location: serve files or return 404
    location / {
        try_files \$uri \$uri/ =404;
    }

    # Redirect /redirect_me to YouTube with 301
    location /redirect_me {
        return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;
    }
}
EOF

# Restart nginx
service nginx restart