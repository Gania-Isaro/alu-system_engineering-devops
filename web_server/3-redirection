#!/usr/bin/env bash
# Configure Nginx to redirect /redirect_me permanently (301)

# Update packages and install nginx
apt-get update -y
apt-get install -y nginx

# Add redirection rule using rewrite for 301 redirection
# The 'permanent' flag in Nginx rewrite performs a 301 redirect
sed -i 's/server_name _;/server_name _;\n\trewrite ^\/redirect_me https:\/\/www.youtube.com\/watch?v=QH2-TGUlwu4 permanent;/' /etc/nginx/sites-available/default

# Restart Nginx to apply changes
service nginx restart