#!/usr/bin/env bash
# configures Nginx server to have a custom 404 page

# Update and install nginx
apt-get update -y
apt-get install nginx -y

# Create custom 404 page
echo "Ceci n'est pas une page" > /var/www/html/custom_404.html

# Configure Nginx to use the custom 404 page
# We insert the error_page directive after the listen line
sed -i "/listen 80 default_server;/a \    error_page 404 /custom_404.html;" /etc/nginx/sites-available/default

# Restart Nginx
service nginx restart
