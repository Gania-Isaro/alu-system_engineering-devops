#!/usr/bin/env bash
# configures Nginx server to have a custom 404 page

# Update and install nginx
apt-get update -y
apt-get install nginx -y

# Create custom 404 page
echo "Ceci n'est pas une page" > /var/www/html/404.html

# Overwrite default config with custom 404 handling
cat <<EOF > /etc/nginx/sites-available/default
##
# Default Nginx site configuration
##

server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.html index.htm index.nginx-debian.html;

    server_name _;

    # Custom 404 page
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    # Default location: serve files or return 404
    location / {
        try_files \$uri \$uri/ =404;
    }

    # Redirect /redirect_me to YouTube with 301
    location /redirect_me {
        return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;
    }
}
EOF

# Restart Nginx
service nginx restart
