#!/usr/bin/env bash
# Adds the provided SSH public key to the server's authorized_keys

PUBLIC_KEY="ssh-rsa "
SERVER_IP="52.70.87.10"
IDENTITY_FILE="~/.ssh/school"

echo "Attempting to add SSH key to $SERVER_IP..."
ssh -o StrictHostKeyChecking=no -i "$IDENTITY_FILE" ubuntu@$SERVER_IP "mkdir -p ~/.ssh && echo '$PUBLIC_KEY' >> ~/.ssh/authorized_keys && chmod 600 ~/.ssh/authorized_keys"

if [ $? -eq 0 ]; then
    echo "Successfully added the SSH key to the server."
else
    echo "Failed to add the SSH key. Please ensure your private key exists at $IDENTITY_FILE and you have the correct passphrase (try 'betty')."
fi
